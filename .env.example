# Copy this file to .env and fill in the values
SECRET_KEY=your-very-secret-django-key-here
DEBUG=False
ALLOWED_HOSTS=your-app-name.onrender.com,localhost

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/gharpayy?retryWrites=true&w=majority
MONGODB_DB=gharpayy
